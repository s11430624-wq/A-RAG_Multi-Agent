+def get_student_transcript_summary(student_id: str) -> dict:
+    from student_system.src import course, grade
+
+    student_record = get_student_by_id(student_id)
+    grades = grade.get_grades_by_student(student_id)
+    courses = []
+    total_credits = 0
+    passed_courses = 0
+    gpas = []
+    for record in sorted(grades, key=lambda item: item["course_id"]):
+        course_record = course.get_course_by_id(record["course_id"])
+        gpa = grade.score_to_gpa(record["score"])
+        passed = record["score"] >= 60
+        total_credits += course_record["credits"]
+        passed_courses += 1 if passed else 0
+        gpas.append(gpa)
+        courses.append({
+            "course_id": course_record["course_id"],
+            "title": course_record["title"],
+            "credits": course_record["credits"],
+            "score": record["score"],
+            "gpa": gpa,
+            "passed": passed,
+        })
+    total_courses = len(courses)
+    pass_rate = round(passed_courses / total_courses, 4) if total_courses else 0.0
+    average_gpa = round(sum(gpas) / total_courses, 4) if total_courses else 0.0
+    return {
+        "student_id": student_record["student_id"],
+        "name": student_record["name"],
+        "total_courses": total_courses,
+        "total_credits": total_credits,
+        "passed_courses": passed_courses,
+        "pass_rate": pass_rate,
+        "average_gpa": average_gpa,
+        "courses": courses,
+    }
