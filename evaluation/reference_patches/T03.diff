+def get_honor_roll_students(min_average_gpa: float = 3.0) -> list[dict]:
+    from student_system.src import grade
+
+    if isinstance(min_average_gpa, bool) or not isinstance(min_average_gpa, (int, float)):
+        raise ValueError("Invalid GPA threshold")
+    if min_average_gpa < 0.0 or min_average_gpa > 4.0:
+        raise ValueError("Invalid GPA threshold")
+
+    qualified = []
+    for student_record in get_all_students():
+        grades = grade.get_grades_by_student(student_record["student_id"])
+        if not grades:
+            continue
+        scores = [record["score"] for record in grades]
+        if any(score < 60 for score in scores):
+            continue
+        gpas = [grade.score_to_gpa(score) for score in scores]
+        average_gpa = round(sum(gpas) / len(gpas), 4)
+        if average_gpa >= float(min_average_gpa):
+            qualified.append({
+                "student_id": student_record["student_id"],
+                "name": student_record["name"],
+                "average_gpa": average_gpa,
+                "total_courses": len(grades),
+            })
+    return sorted(qualified, key=lambda item: (-item["average_gpa"], item["student_id"]))
