+def summarize_grade_records(records: list[dict]) -> dict:
+    from student_system.src import grade
+
+    total_courses = len(records)
+    if total_courses == 0:
+        return {
+            "total_courses": 0,
+            "passed_courses": 0,
+            "failed_courses": 0,
+            "pass_rate": 0.0,
+            "average_gpa": 0.0,
+        }
+
+    passed_courses = sum(1 for record in records if record["score"] >= 60)
+    failed_courses = total_courses - passed_courses
+    average_gpa = round(sum(grade.score_to_gpa(record["score"]) for record in records) / total_courses, 4)
+    pass_rate = round(passed_courses / total_courses, 4)
+    return {
+        "total_courses": total_courses,
+        "passed_courses": passed_courses,
+        "failed_courses": failed_courses,
+        "pass_rate": pass_rate,
+        "average_gpa": average_gpa,
+    }
