+def preview_bulk_score_update(updates: list[dict]) -> dict:
+    from student_system.src import course, student, utils
+
+    valid_updates = []
+    invalid_updates = []
+    for index, item in enumerate(updates):
+        try:
+            student.get_student_by_id(item["student_id"])
+            course.get_course_by_id(item["course_id"])
+            utils.validate_score(item["score"])
+            normalized_score = float(item["score"])
+            if normalized_score.is_integer():
+                normalized_score = int(normalized_score)
+            valid_updates.append({
+                "student_id": item["student_id"],
+                "course_id": item["course_id"],
+                "score": item["score"],
+                "normalized_score": normalized_score,
+                "gpa": score_to_gpa(normalized_score),
+            })
+        except Exception as exc:
+            invalid_updates.append({
+                "index": index,
+                "input": dict(item),
+                "reason": str(exc),
+            })
+    return {
+        "valid_updates": valid_updates,
+        "invalid_updates": invalid_updates,
+        "summary": {
+            "total": len(updates),
+            "valid": len(valid_updates),
+            "invalid": len(invalid_updates),
+        },
+    }
