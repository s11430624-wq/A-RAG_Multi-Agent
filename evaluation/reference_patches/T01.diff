+
+def get_course_leaderboard(course_id: str) -> list[dict]:
+    from student_system.src import grade, student
+
+    get_course_by_id(course_id)
+    grades = grade.get_grades_by_course(course_id)
+    ranked = sorted(grades, key=lambda item: (-item["score"], item["student_id"]))
+    leaderboard = []
+    for index, record in enumerate(ranked, start=1):
+        student_record = student.get_student_by_id(record["student_id"])
+        leaderboard.append(
+            {
+                "rank": index,
+                "student_id": record["student_id"],
+                "name": student_record["name"],
+                "score": record["score"],
+                "gpa": grade.score_to_gpa(record["score"]),
+            }
+        )
+    return leaderboard
