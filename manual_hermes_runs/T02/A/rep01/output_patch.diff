+def get_student_course_summary(student_id: str) -> dict:
+    student = get_student_by_id(student_id)
+    student_grades = grade.get_grades_by_student(student_id)
+
+    course_list = []
+    for g in student_grades:
+        c = course.get_course_by_id(g["course_id"])
+        course_list.append({"title": c["title"], "credits": c["credits"]})
