+
+def get_student_course_summary(student_id: str) -> dict:
+    from student_system.src import grade, course
+
+    # Ensure student exists
+    student = get_student_by_id(student_id)
+
+    # Retrieve grades for the student
+    grades = grade.get_grades_by_student(student_id)
+
+    summary_courses = []
+    for g in grades:
+        c = course.get_course_by_id(g["course_id"])
+        summary_courses.append({
+            "title": c["title"],
+            "credits": c["credits"]
+        })
+
+    return {
+        "student_id": student_id,
+        "courses": summary_courses
+    }
